   
           
     {
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DocMetrics",
  "colors": {
    "primary": "#0ea5e9",
    "light": "#38bdf8",
    "dark": "#0284c7"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
